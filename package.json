{
  "name": "pricing-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathIgnorePatterns test/integration --passWithNoTests",
    "test:integration": "jest test/integration --passWithNoTests",
    "migrate": "DATABASE_URL=$(grep ^DATABASE_URL= .env | cut -d= -f2-) node-pg-migrate up",
    "migrate:down": "DATABASE_URL=$(grep ^DATABASE_URL= .env | cut -d= -f2-) node-pg-migrate down",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.3.1",
    "pg": "^8.22.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
